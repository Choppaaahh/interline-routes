# Interline — copy to .env and fill. .env is gitignored. NEVER commit real keys.

# Network mode: mock | base-sepolia | base
#   mock         = in-process facilitator, no chain, no keys (default — run_demo works as-is)
#   base-sepolia = real testnet (faucet USDC, $0 real value)
#   base         = mainnet (NOT for v0)
APV0_NETWORK=mock

# Buyer wallet (signs EIP-3009 USDC authorizations). Base Sepolia TESTNET key only.
# Get one: any wallet's "export private key", or `python3 -c "from eth_account import Account; a=Account.create(); print(a.address, a.key.hex())"`
APV0_BUYER_PRIVATE_KEY=

# Seller wallet (receives USDC). Address only — seller never signs.
APV0_SELLER_ADDRESS=

# Facilitator (verifies + settles). Leave blank to use the default per network mode.
#   mock  -> in-process
#   live  -> https://x402.org/facilitator  (or self-host PayAI)
APV0_FACILITATOR_URL=

# Price per unit of work, in USDC.
APV0_PRICE_USDC=0.001

# --- v1 dogfood: the WORK the seller performs once paid ---
# If set, the seller does a REAL OpenRouter model call (pay an agent → it does
# real inference for you). If unset, returns a local stub. This is the product's
# integration point — a deployer plugs in their own model/compute/service.
APV0_OPENROUTER_KEY=
APV0_WORK_MODEL=google/gemini-2.5-flash-lite
